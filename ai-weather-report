"""ai-weather-report - Generate an AI news audio briefing from RSS feeds."""

import argparse
import configparser
import json
import sys
from datetime import datetime, timedelta, timezone
from pathlib import Path

CONFIG_PATH = Path.home() / ".ai-weather-report"

DEFAULT_FEEDS = {
