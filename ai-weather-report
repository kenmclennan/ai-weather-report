    "provider": "anthropic",
    "model": "claude-sonnet-4-20250514",
    "api_key": "",
    "api_url": "",
}

TTS_REQUIRED = ("api_url", "api_key", "voice")
CHUNK_SIZE = 1000
DEFAULT_DAYS = 3
MAX_ARTICLE_CHARS = 6000

SUMMARY_SYSTEM = (
    "You are a news analyst. Given a full article, write a 2-3 sentence summary "
    "capturing the key facts: what happened, who is involved, and why it matters. "
    "Be factual and concise. No bullet points or formatting. Just the summary."
)

